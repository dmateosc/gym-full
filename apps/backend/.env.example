# ── Base de datos ─────────────────────────────────────────────────────────────
# Nombre del contenedor o hostname del servicio PostgreSQL en la red Docker
DATABASE_URL=postgresql://postgres:password@postgres:5432/gymdb
DATABASE_SSL=false

# ── Autenticación (Supabase JWT) ───────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Aplicación ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
API_BASE_URL=http://gym.3dmc.lab

# ── CORS ───────────────────────────────────────────────────────────────────────
# Orígenes permitidos separados por coma
CORS_ORIGINS=http://gym.3dmc.lab,http://localhost:5173
