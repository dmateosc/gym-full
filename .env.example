# ================================================================
# Variables de entorno — Centro Wellness Sierra de Gata
# Copia este archivo como .env y rellena los valores reales
# ================================================================

# ─── Supabase ──────────────────────────────────────────────────
# Obtén estas claves en: https://supabase.com/dashboard → tu proyecto → API

# URL del proyecto Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anónima (pública, segura para el frontend)
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# ─── Backend (NestJS) ──────────────────────────────────────────
# URL de la base de datos PostgreSQL (Supabase → Settings → Database)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# JWT Secret de Supabase (para verificar tokens en el backend)
# Obtén en: Supabase → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=tu-jwt-secret-aqui

# Service Role Key (solo backend, NUNCA expongas al frontend)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# ─── API (Frontend) ───────────────────────────────────────────
# URL del backend API (en desarrollo: http://localhost:3001/api)
VITE_API_BASE_URL=http://localhost:3001/api
VITE_BACKEND_URL=http://localhost:3001/api

# ─── OpenAI (para generación de rutinas con IA) ───────────────
OPENAI_API_KEY=tu-openai-api-key-aqui

# ─── Vercel (solo para CI/CD) ─────────────────────────────────
# Obtén en: https://vercel.com/account/tokens
VERCEL_TOKEN=tu-vercel-token
VERCEL_ORG_ID=tu-org-id
VERCEL_PROJECT_ID=tu-project-id-frontend
VERCEL_PROJECT_ID_BACKEND=tu-project-id-backend
